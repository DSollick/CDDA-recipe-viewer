{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cdda-recipe",
  "title": "CDDA Recipe",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": { "const": "recipe" },
    "result": { "type": "string" },
    "copy-from": { "type": "string" },
    "variant": { "type": "string" }
  },
  "if": { "not": { "required": ["copy-from"] } },
  "then": { "required": ["result"] }
}
